# TailoredTunes Backend — Environment Variables
# Copy this to .env and fill in real values
# NEVER commit .env to git

# ── Supabase ─────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── TemPolor AI Music Generation ─────────────────────────
TEMPOLOR_API_KEY=your_tempolor_api_key
TEMPOLOR_BASE_URL=https://api.tempolor.com
TEMPOLOR_SONG_MODEL=tempolor-song-v2
TEMPOLOR_INSTRUMENTAL_MODEL=tempolor-instrumental-v2

# ── Stripe ───────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_PREMIUM=price_...

# ── Security ─────────────────────────────────────────────
JWT_SECRET=replace_with_32_plus_random_chars_openssl_rand_base64_32

# ── Server ───────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
